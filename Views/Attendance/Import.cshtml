@{
    ViewData["Title"] = "Import Chấm Công IoT";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-excel"></i> Nhập Dữ Liệu Chấm Công Từ Thiết Bị IoT</h5>
                </div>
                <div class="card-body p-4">

                    <div class="alert alert-info bg-light border-info">
                        <h6 class="text-info"><i class="bi bi-info-circle-fill"></i> Hướng dẫn định dạng file Excel:</h6>
                        <ul class="mb-0 small text-secondary">
                            <li><strong>Dòng 1:</strong> Bắt buộc là dòng tiêu đề (Header).</li>
                            <li><strong>Cột A:</strong> Mã nhân viên (VD: NV001)</li>
                            <li><strong>Cột B:</strong> Ngày chấm công (VD: 25/12/2023)</li>
                            <li><strong>Cột C:</strong> Giờ Check-in (VD: 08:15)</li>
                            <li><strong>Cột D:</strong> Giờ Check-out (VD: 17:30)</li>
                        </ul>
                    </div>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                        </div>
                    }
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                        </div>
                    }
                    @if (TempData["WarningMessage"] != null)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-circle-fill"></i> @TempData["WarningMessage"]
                        </div>

                        @if (ViewBag.ErrorList != null)
                        {
                            <div class="bg-light p-3 rounded border text-danger small mt-2" style="max-height: 200px; overflow-y: auto;">
                                <ul class="mb-0">
                                    @foreach (var err in ViewBag.ErrorList)
                                    {
                                        <li>@err</li>
                                    }
                                </ul>
                            </div>
                        }
                    }

                    <form asp-action="Import" asp-controller="Attendance" method="post" enctype="multipart/form-data" class="mt-4">
                        <div class="mb-4">
                            <label for="fileExcel" class="form-label fw-bold">Chọn file dữ liệu (.xlsx)</label>
                            <input class="form-control form-control-lg" type="file" id="fileExcel" name="fileExcel" accept=".xlsx, .xls" required>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-cloud-arrow-up-fill"></i> Tải lên và Cập nhật
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>