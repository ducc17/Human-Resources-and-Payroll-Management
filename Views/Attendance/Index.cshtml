@model List<SmartHR_Payroll.Models.Attendance>

@{
    ViewData["Title"] = "Bảng Chấm Công Tổng Hợp";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Tìm nhân viên</label>
                        <input type="text" name="search" class="form-control form-control-sm" value="@ViewBag.Search" placeholder="Tên / Mã NV...">
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Phòng ban</label>
                        <select name="departmentId" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var dept in ViewBag.Departments)
                                {
                                    // Chú ý: Thay DepartmentId và Name cho khớp với Model Department của bạn
                                    if (ViewBag.DepartmentId != null && ViewBag.DepartmentId == dept.DepartmentId)
                                    {
                                        <option value="@dept.DepartmentId" selected>@dept.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@dept.DepartmentId">@dept.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Từ ngày</label>
                        <input type="date" name="fromDate" class="form-control form-control-sm" value="@ViewBag.FromDate">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Đến ngày</label>
                        <input type="date" name="toDate" class="form-control form-control-sm" value="@ViewBag.ToDate">
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Trạng thái</label>
                        <select name="status" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            <option value="ontime" selected="@(ViewBag.Status == "ontime")">Đúng giờ</option>
                            <option value="late" selected="@(ViewBag.Status == "late")">Đi trễ</option>
                            <option value="absent" selected="@(ViewBag.Status == "absent")">Vắng</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex gap-1">
                        <button type="submit" class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-search"></i> Lọc</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-clockwise"></i>xóa</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-people-fill"></i> Dữ liệu chấm công</h5>
            <div>
                <a asp-action="Import" class="btn btn-success btn-sm">
                    <i class="bi bi-file-earmark-excel"></i> Import Excel
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Mã NV</th>
                            <th class="text-start">Họ và tên</th>
                            <th class="text-start">Phòng ban</th>
                            <th class="text-start">Vị trí</th>
                            <th>Ngày làm việc</th>
                            <th>Giờ vào</th>
                            <th>Giờ ra</th>
                            <th>Trạng thái</th>
                            <th>Note</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">@item.Employee?.EmployeeCode</td>
                                    <td class="text-start fw-bold">@item.Employee?.FullName</td>

                                    <td class="text-start"><span class="badge bg-secondary">@(item.Employee?.Department?.Name ?? "N/A")</span></td>
                                    <td class="text-start text-muted small">@(item.Employee?.Position?.Name ?? "N/A")</td>

                                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                    <td class="text-success fw-bold">@(item.CheckInTime?.ToString(@"hh\:mm") ?? "--:--")</td>
                                    <td class="text-danger fw-bold">@(item.CheckOutTime?.ToString(@"hh\:mm") ?? "--:--")</td>
                                    <td>
                                        @if (item.IsLate)
                                        {
                                            <span class="badge bg-warning text-dark">Đi trễ</span>
                                        }
                                        else if (item.CheckInTime.HasValue)
                                        {
                                            <span class="badge bg-success">Đúng giờ</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border">Vắng</span>
                                        }
                                    </td>                          
                                    <td class="small text-muted fst-italic">@item.Note</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-search fs-1 d-block mb-2"></i>
                                    Không tìm thấy dữ liệu nào phù hợp với bộ lọc.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>