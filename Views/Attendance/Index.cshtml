@model IEnumerable<SmartHR_Payroll.ViewModels.Attendance.DailyAttendanceViewModel>

@{
    ViewData["Title"] = "Bảng Chấm Công Tổng Hợp";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Tìm nhân viên</label>
                        <input type="text" name="search" class="form-control form-control-sm" value="@ViewBag.Search" placeholder="Tên / Mã NV...">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Phòng ban</label>
                        <select name="departmentId" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var dept in ViewBag.Departments)
                                {
                                    if (ViewBag.DepartmentId != null && ViewBag.DepartmentId == dept.DepartmentId)
                                    {
                                        <option value="@dept.DepartmentId" selected>@dept.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@dept.DepartmentId">@dept.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Từ ngày</label>
                        <input type="date" name="fromDate" class="form-control form-control-sm" value="@ViewBag.FromDate">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Đến ngày</label>
                        <input type="date" name="toDate" class="form-control form-control-sm" value="@ViewBag.ToDate">
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Trạng thái</label>
                        <select name="status" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            <option value="HopLe" selected="@(ViewBag.Status == "HopLe")">Hợp lệ</option>
                            <option value="KhongHopLe" selected="@(ViewBag.Status == "KhongHopLe")">Thiếu/Muộn</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex gap-1">
                        <button type="submit" class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-search"></i> Lọc</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-clockwise"></i>xóa</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-people-fill"></i> Dữ liệu chấm công</h5>
            <div>
                <a asp-action="Import" class="btn btn-success btn-sm">
                    <i class="bi bi-file-earmark-excel"></i> Import Excel
                </a>
            </div>
        </div>
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã NV</th>
                                <th>Họ Tên</th>
                                <th>Phòng Ban</th>
                                <th>Ngày</th>
                                <th>Check-in (Sớm nhất)</th>
                                <th>Check-out (Muộn nhất)</th>
                                <th>Tổng giờ</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr><td colspan="9" class="text-center text-muted">Không có dữ liệu.</td></tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    // Tạo 1 ID duy nhất cho tính năng Xổ xuống (Collapse)
                                    string collapseId = $"collapse_{item.EmployeeId}_{item.Date.ToString("yyyyMMdd")}";

                                    <tr>
                                        <td class="fw-bold text-primary">@item.EmployeeCode</td>
                                        <td>@item.FullName</td>
                                        <td>@item.DepartmentName</td>
                                        <td>@item.Date.ToString("dd/MM/yyyy")</td>

                                        <td class="text-success fw-bold">
                                            @(item.FirstCheckIn.HasValue? item.FirstCheckIn.Value.ToString(@"hh\:mm") : "--:--")
                                        </td>
                                        <td class="text-danger fw-bold">
                                            @(item.LastCheckOut.HasValue? item.LastCheckOut.Value.ToString(@"hh\:mm") : "--:--")
                                        </td>

                                        <td>@item.TotalHours giờ</td>
                                        <td>
                                            @if (item.IsPerfect)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Hợp lệ</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Thiếu/Muộn</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                                Xem chi tiết (@item.Details.Count)
                                            </button>
                                        </td>
                                    </tr>

                                    <tr class="collapse bg-light" id="@collapseId">
                                        <td colspan="9" class="p-3 border-bottom">
                                            <div class="ps-4 border-start border-info border-3">
                                                <h6 class="text-muted mb-2"><i class="bi bi-clock-history"></i> Chi tiết các lần quẹt thẻ ngày @item.Date.ToString("dd/MM/yyyy")</h6>
                                                <table class="table table-sm table-bordered bg-white mb-0 w-50">
                                                    <thead class="table-secondary">
                                                        <tr>
                                                            <th>STT</th>
                                                            <th>Giờ ghi nhận (In)</th>
                                                            <th>Giờ ghi nhận (Out)</th>
                                                            <th>Ghi chú (Note)</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @{
                                                            int stt = 1;
                                                        }
                                                        @foreach (var detail in item.Details)
                                                        {
                                                            <tr>
                                                                <td>@stt</td>
                                                                <td>@(detail.CheckInTime.HasValue? detail.CheckInTime.Value.ToString(@"hh\:mm") : "---")</td>
                                                                <td>@(detail.CheckOutTime.HasValue? detail.CheckOutTime.Value.ToString(@"hh\:mm") : "---")</td>
                                                                <td class="text-muted fst-italic">@detail.Note</td>
                                                            </tr>
                                                            stt++;
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                          
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                @{
                    int currentPage = ViewBag.CurrentPage ?? 1;
                    int totalPages = ViewBag.TotalPages ?? 1;
                }

                @if (totalPages > 1)
                {
                    <nav aria-label="Page navigation" class="mt-4">
                        <ul class="pagination justify-content-center mb-0">

                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(currentPage - 1)"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-departmentId="@ViewBag.DepartmentId"
                                   asp-route-fromDate="@ViewBag.FromDate"
                                   asp-route-toDate="@ViewBag.ToDate"
                                   asp-route-status="@ViewBag.Status">
                                    <i class="bi bi-chevron-left"></i> Trước
                                </a>
                            </li>

                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-search="@ViewBag.Search"
                                       asp-route-departmentId="@ViewBag.DepartmentId"
                                       asp-route-fromDate="@ViewBag.FromDate"
                                       asp-route-toDate="@ViewBag.ToDate"
                                       asp-route-status="@ViewBag.Status">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(currentPage + 1)"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-departmentId="@ViewBag.DepartmentId"
                                   asp-route-fromDate="@ViewBag.FromDate"
                                   asp-route-toDate="@ViewBag.ToDate"
                                   asp-route-status="@ViewBag.Status">
                                    Sau <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                        </ul>
                    </nav>
                }

            </div>
        </div>
    </div>
</div>