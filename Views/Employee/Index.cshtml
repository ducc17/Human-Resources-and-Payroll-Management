@model SmartHR_Payroll.ViewModels.Employee.EmployeeListViewModel
@using SmartHR_Payroll.Models

@{
    ViewData["Title"] = "Danh sách nhân viên";
}

<style>
    .employee-table {
        min-width: 1800px;
    }

    .employee-table thead th {
        background: #f8fafc;
        color: #334155;
        font-weight: 700;
        font-size: 0.9rem;
        white-space: nowrap;
        border-bottom: 1px solid #dbe4ee;
        vertical-align: middle;
    }

    .employee-table tbody td {
        white-space: nowrap;
        vertical-align: middle;
    }

    .employee-table tbody tr:hover {
        background-color: #f8fbff;
    }

    .action-icon-btn {
        width: 2rem;
        height: 2rem;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
        <div>
            <h4 class="fw-bold mb-1"><i class="fa-solid fa-users text-primary me-2"></i>Danh sách nhân viên</h4>
            <p class="text-muted mb-3">Quản lý toàn bộ nhân viên, ban account mềm và xem hợp đồng theo nhân viên.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-user-plus me-1"></i>Thêm nhân viên
        </a>
    </div>

    <div class="card-body pt-2">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        @if (!Model.Employees.Any())
        {
            <div class="alert alert-info mb-0">Chưa có nhân viên nào.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle employee-table">
                    <thead class="table-light">
                        <tr>
                            <th>Mã NV</th>
                            <th>Họ tên</th>
                            <th>Ngày sinh</th>
                            <th>Ngày vào làm</th>
                            <th>Giới tính</th>
                            <th>Địa chỉ</th>
                            <th>Ngày tạo</th>
                            <th>Người tạo</th>
                            <th>Ngày cập nhật</th>
                            <th>Người cập nhật</th>
                            <th>Phòng ban</th>
                            <th>Chức vụ</th>
                            <th>Email</th>
                            <th>Số điện thoại</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model.Employees)
                        {
                            <tr>
                                <td class="fw-semibold">@employee.EmployeeCode</td>
                                <td>@employee.FullName</td>
                                <td>@employee.DateOfBirth.ToString("dd/MM/yyyy")</td>
                                <td>@employee.HireDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (employee.Gender == Status.Gender.Male)
                                    {
                                        <span>Nam</span>
                                    }
                                    else if (employee.Gender == Status.Gender.Female)
                                    {
                                        <span>Nữ</span>
                                    }
                                    else
                                    {
                                        <span>Khác</span>
                                    }
                                </td>
                                <td>@employee.Address</td>
                                <td>@employee.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@employee.CreatedBy</td>
                                <td>@(employee.UpdatedAt.HasValue ? employee.UpdatedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(employee.UpdatedBy) ? "-" : employee.UpdatedBy)</td>
                                <td>@employee.DepartmentName</td>
                                <td>@employee.PositionName</td>
                                <td>@employee.Email</td>
                                <td>@employee.PhoneNumber</td>
                                <td>
                                    @if (employee.Status == Status.EmployeeStatus.Active)
                                    {
                                        <span class="badge bg-success">Đang làm việc</span>
                                    }
                                    else if (employee.Status == Status.EmployeeStatus.OnLeave)
                                    {
                                        <span class="badge bg-warning text-dark">Nghỉ phép</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã nghỉ việc</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Contracts"
                                           asp-route-employeeId="@employee.EmployeeId"
                                           class="btn btn-outline-primary btn-sm action-icon-btn"
                                           title="Xem hợp đồng">
                                            <i class="fa-solid fa-file-contract"></i>
                                        </a>

                                        @if (employee.Status == Status.EmployeeStatus.Terminated)
                                        {
                                            <form asp-action="Unban" method="post" onsubmit="return confirm('Bạn có chắc muốn mở khóa account nhân viên này?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="employeeId" value="@employee.EmployeeId" />
                                                <input type="hidden" name="page" value="@Model.CurrentPage" />
                                                <button type="submit"
                                                        class="btn btn-outline-success btn-sm action-icon-btn"
                                                        title="Unban account">
                                                    <i class="fa-solid fa-user-check"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Ban" method="post" onsubmit="return confirm('Bạn có chắc muốn ban account nhân viên này?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="employeeId" value="@employee.EmployeeId" />
                                                <input type="hidden" name="page" value="@Model.CurrentPage" />
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-sm action-icon-btn"
                                                        title="Ban account">
                                                    <i class="fa-solid fa-user-slash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="text-muted small">
                    Tổng: <strong>@Model.TotalCount</strong> nhân viên
                </div>

                <nav aria-label="Phân trang nhân viên">
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Trước</a>
                        </li>

                        @for (var i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
