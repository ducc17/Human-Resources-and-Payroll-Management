@model SmartHR_Payroll.ViewModels.Employee.AddEmployeeDeductionViewModel

@{
    ViewData["Title"] = "Thêm khoản trừ cho nhân viên";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 pt-4 pb-0">
        <h4 class="fw-bold mb-1"><i class="fa-solid fa-circle-plus text-primary me-2"></i>Thêm khoản trừ</h4>
        <p class="text-muted mb-3">Chọn khoản trừ và nhập số tiền áp dụng cho nhân viên.</p>
    </div>

    <div class="card-body pt-2">
        <div class="alert alert-light border d-flex gap-4 flex-wrap">
            <div><strong>Mã NV:</strong> @Model.EmployeeCode</div>
            <div><strong>Họ tên:</strong> @Model.FullName</div>
        </div>

        <form asp-action="AddDeduction" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger mb-3" role="alert"></div>

            <input asp-for="EmployeeId" type="hidden" />
            <input asp-for="EmployeeCode" type="hidden" />
            <input asp-for="FullName" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="DeductionId" class="form-label">Khoản trừ</label>
                    <select asp-for="DeductionId" class="form-select" asp-items="ViewBag.Deductions">
                        <option value="">-- Chọn khoản trừ --</option>
                    </select>
                    <span asp-validation-for="DeductionId" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Amount" class="form-label">Số tiền</label>
                    <input asp-for="Amount" type="text" inputmode="decimal" class="form-control" placeholder="VD: 500000" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="EffectiveDate" class="form-label">Ngày áp dụng</label>
                    <input asp-for="EffectiveDate" type="date" class="form-control" />
                    <span asp-validation-for="EffectiveDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Lưu khoản trừ
                </button>
                <a asp-action="AddDeduction"
                   asp-route-employeeId="@Model.EmployeeId"
                   class="btn btn-outline-secondary">Quay lại khoản trừ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
