@model SmartHR_Payroll.ViewModels.Employee.EmployeeAllowanceListViewModel

@{
    ViewData["Title"] = "Khoản phụ cấp nhân viên";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 pt-4 pb-0">
        <h4 class="fw-bold mb-1"><i class="fa-solid fa-hand-holding-dollar text-primary me-2"></i>Khoản phụ cấp của nhân viên</h4>
        <p class="text-muted mb-3">Danh sách các khoản phụ cấp đã áp dụng cho nhân viên.</p>
    </div>

    <div class="card-body pt-2">
        <div class="alert alert-light border d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <div class="d-flex gap-4 flex-wrap">
                <div><strong>Mã NV:</strong> @Model.EmployeeCode</div>
                <div><strong>Họ tên:</strong> @Model.FullName</div>
            </div>

            <a asp-action="AddAllowanceCreate"
               asp-route-employeeId="@Model.EmployeeId"
               asp-route-page="@Model.Page"
               asp-route-keyword="@Model.Keyword"
               asp-route-status="@Model.Status"
               class="btn btn-primary">
                <i class="fa-solid fa-circle-plus me-1"></i>Thêm khoản phụ cấp
            </a>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="alert alert-info">Nhân viên chưa có khoản phụ cấp nào.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tên phụ cấp</th>
                            <th>Số tiền</th>
                            <th>Ngày áp dụng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="fw-semibold">@item.AllowanceName</td>
                                <td>@item.Amount.ToString("N0")</td>
                                <td>@item.EffectiveDate.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="mt-3">
            <a asp-action="Index"
               asp-route-page="@Model.Page"
               asp-route-keyword="@Model.Keyword"
               asp-route-status="@Model.Status"
               class="btn btn-outline-secondary">Quay lại danh sách nhân viên</a>
        </div>
    </div>
</div>
