@model SmartHR_Payroll.Models.Deduction

@{
    ViewData["Title"] = "Thêm khấu trừ";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 pt-4 pb-0">
        <h4 class="fw-bold mb-1"><i class="fa-solid fa-circle-plus text-primary me-2"></i>Thêm mới khấu trừ</h4>
        <p class="text-muted mb-3">Nhập thông tin khấu trừ và lưu vào hệ thống.</p>
    </div>
    <div class="card-body pt-2">
        <form asp-action="Create" method="post" class="needs-validation" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">Tên khấu trừ</label>
                    <input asp-for="Name" class="form-control" placeholder="Ví dụ: Khấu trừ đi muộn, Khấu trừ BHXH bổ sung..." required />
                    <div class="invalid-feedback">Vui lòng nhập tên khấu trừ.</div>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Lưu khấu trừ
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
}
