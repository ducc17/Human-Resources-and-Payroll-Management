@using System.Security.Claims
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartHR</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar {
            padding: 15px 0;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-layer-group me-2"></i>SmartHR
            </a>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <!-- Chỉ hiện menu nếu đã đăng nhập -->
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                        </li>

                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" asp-controller="Employee" asp-action="Index">Nhân viên</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" asp-controller="Employee" asp-action="Create">Thêm nhân viên</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" asp-controller="Contract" asp-action="Create">Tạo hợp đồng</a>
                            </li>
                        }
                    }
                </ul>

                <!-- GÓC PHẢI MÀN HÌNH -->
                <div class="d-flex align-items-center">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <!-- Đã đăng nhập: Hiện Avatar và Đăng xuất -->
                        <div class="text-end me-3 text-white">
                            <div class="fw-bold text-truncate" style="font-size: 14px; max-width: 150px;">@User.FindFirst(ClaimTypes.Name)?.Value</div>
                        </div>
                        <img src="@User.FindFirst("Avatar")?.Value" alt="Avatar" class="rounded-circle shadow-sm me-3" width="40" height="40" style="border: 2px solid white;" />

                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-light btn-sm fw-bold text-danger rounded-pill px-3 shadow-sm">
                                <i class="fa-solid fa-right-from-bracket me-1"></i> Thoát
                            </button>
                        </form>
                    }
                    else
                    {
                        <!-- Chưa đăng nhập: Hiện nút Đăng nhập -->
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-light btn-sm fw-bold text-primary rounded-pill px-4 shadow-sm">
                            <i class="fa-regular fa-user me-1"></i> Đăng nhập
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- NỘI DUNG CÁC TRANG SẼ ĐƯỢC NHÉT VÀO ĐÂY -->
    <div class="container mt-4 mb-5">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>