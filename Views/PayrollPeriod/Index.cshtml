@model IEnumerable<SmartHR_Payroll.ViewModels.PayrollPeriod.PayrollPeriodViewModel>
@using SmartHR_Payroll.Models
@{
    ViewData["Title"] = "Quản lý Kỳ Lương";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark"><i class="fa-solid fa-calendar-check text-primary me-2"></i>Danh sách Kỳ Lương</h3>
    <a asp-controller="PayrollPeriod" asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Tạo kỳ lương mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover table-borderless align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Kỳ Lương</th>
                    <th>Thời gian</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Số NV</th>
                    <th class="text-end">Tổng quỹ lương (VNĐ)</th>
                    <th class="text-center pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Chưa có kỳ lương nào được tạo.</td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.Name</td>
                        <td class="text-muted">@item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @if (item.Status == Status.PayrollStatus.Draft)
                            {
                                <span class="badge bg-secondary">Bản nháp</span>
                            }
                            else if (item.Status == Status.PayrollStatus.Processing)
                            {
                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đã duyệt</span>
                            }
                        </td>
                        <td class="text-center fw-semibold">@item.TotalEmployees</td>
                        <td class="text-end text-danger fw-bold">@item.TotalNetSalary.ToString("N0")</td>
                        <td class="text-center pe-4">
                            <!-- Nối link chuẩn MVC -->
                            <a asp-controller="PayrollPeriod" asp-action="PayrollSheet" asp-route-id="@item.PayrollPeriodId" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold">
                                <i class="fa-solid fa-table-list me-1"></i> Bảng lương
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>