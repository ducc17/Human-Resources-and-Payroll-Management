@model IEnumerable<SmartHR_Payroll.ViewModels.Insurance.InsuranceViewModel>
@{
    ViewData["Title"] = "Cấu hình Bảo hiểm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark"><i class="fa-solid fa-shield-heart text-primary me-2"></i>Quy định Bảo hiểm</h3>
    <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Thêm mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover table-borderless align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Mã</th>
                    <th>Tên Bảo hiểm</th>
                    <th class="text-center">NV Đóng (%)</th>
                    <th class="text-center">CTY Đóng (%)</th>
                    <th class="text-end">Mức trần (VNĐ)</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.Code</td>
                        <td>@item.Name</td>
                        <td class="text-center text-danger fw-semibold">@item.EmployeeRate.ToString("0.0") %</td>
                        <td class="text-center text-success fw-semibold">@item.CompanyRate.ToString("0.0") %</td>
                        <td class="text-end text-muted">
                            @(item.MaxSalaryLimit.HasValue? item.MaxSalaryLimit.Value.ToString("N0") : "Không giới hạn")
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.InsuranceId" class="btn btn-sm btn-outline-primary rounded-circle"><i class="fa-solid fa-pen"></i></a>
                            <form asp-action="Delete" asp-route-id="@item.InsuranceId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>