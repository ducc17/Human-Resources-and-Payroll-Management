@model SmartHR_Payroll.Models.Role

<div class="container mt-4">
    <div class="card shadow-sm border-0 w-50 mx-auto">
        <div class="card-header bg-primary text-white"><h5 class="mb-0">Thêm mới Vai trò</h5></div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên vai trò (Quyền)</label>
                    <input asp-for="Name" class="form-control" placeholder="Ví dụ: Admin, HR, Employee..." required />
                    <div class="invalid-feedback">Vui lòng nhập tên vai trò.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả chi tiết quyền hạn..."></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Lưu dữ liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
}S