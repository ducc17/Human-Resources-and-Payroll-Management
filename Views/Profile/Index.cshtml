@model SmartHR_Payroll.ViewModels.Profile.ProfileViewModel

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-3 col-md-4 mb-4">

            <div class="card shadow-sm text-center p-4 mb-3 border-0">
                <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=random&size=128"
                     class="rounded-circle mx-auto mb-3" alt="Avatar" width="120">
                <h5 class="mb-1 fw-bold">@Model.FullName</h5>
                <p class="text-muted mb-2 small">@Model.PositionName</p>
                <span class="badge bg-primary">@Model.DepartmentName</span>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold text-uppercase small text-muted py-3">
                    <i class="bi bi-grid-fill me-1"></i> Tùy chọn
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Edit" class="list-group-item list-group-item-action py-3">
                        <i class="bi bi-pencil-square text-primary me-2"></i> Cập nhật thông tin
                    </a>
                    <a asp-controller="Attendance" asp-action="MyHistory" class="list-group-item list-group-item-action py-3">
                        <i class="bi bi-clock-history text-info me-2"></i> Lịch sử chấm công
                    </a>
                    <a asp-controller="Employee" asp-action="MyContracts" class="list-group-item list-group-item-action py-3">
                        <i class="bi bi-file-earmark-check text-success me-2"></i> Xác nhận hợp đồng
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">

            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white fw-bold py-3">
                    <i class="bi bi-person-lines-fill text-primary"></i> Thông tin liên hệ
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Mã NV</div>
                        <div class="col-sm-9 fw-bold">@Model.EmployeeCode</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Ngày tham gia</div>
                        <div class="col-sm-9 fw-bold">@Model.HireDate</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Email</div>
                        <div class="col-sm-9">@Model.Email</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Số điện thoại</div>
                        <div class="col-sm-9">@Model.PhoneNumber</div>
                    </div>
                    <div class="row">
                        <div class="col-sm-3 text-muted">Địa chỉ</div>
                        <div class="col-sm-9">@Model.Address</div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold py-3">
                    <i class="bi bi-bank2 text-success"></i> Thông tin nhận lương
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Ngân hàng</div>
                        <div class="col-sm-9">@(string.IsNullOrEmpty(Model.BankName) ? "Chưa cập nhật" : Model.BankName)</div>
                    </div>
                    <div class="row">
                        <div class="col-sm-3 text-muted">Số tài khoản</div>
                        <div class="col-sm-9 fw-bold text-success">@(string.IsNullOrEmpty(Model.BankAccountNumber) ? "Chưa cập nhật" : Model.BankAccountNumber)</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>