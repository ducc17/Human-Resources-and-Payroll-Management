@model SmartHR_Payroll.ViewModels.TaxBracket.TaxBracketViewModel
@{
    ViewData["Title"] = "Sửa Bậc Thuế";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark">Cập nhật Bậc Thuế TNCN</h3>
    <a asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm">
        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4" style="max-width: 800px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="TaxBracketId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="Level" class="form-label fw-bold">Bậc thuế số <span class="text-danger">*</span></label>
                    <input asp-for="Level" type="number" class="form-control bg-light" readonly />
                    <span asp-validation-for="Level" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FromIncome" class="form-label fw-bold">Thu nhập TỪ (VNĐ) <span class="text-danger">*</span></label>
                    <input asp-for="FromIncome" type="number" class="form-control" />
                    <span asp-validation-for="FromIncome" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ToIncome" class="form-label fw-bold">Thu nhập ĐẾN (VNĐ)</label>
                    <input asp-for="ToIncome" type="number" class="form-control" />
                    <span asp-validation-for="ToIncome" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="TaxRate" class="form-label fw-bold">Thuế suất (%) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="TaxRate" type="number" step="0.01" class="form-control" />
                        <span class="input-group-text bg-light">%</span>
                    </div>
                    <span asp-validation-for="TaxRate" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="QuickSubtraction" class="form-label fw-bold">Mức trừ lùi (VNĐ) <span class="text-danger">*</span></label>
                    <input asp-for="QuickSubtraction" type="number" class="form-control" />
                    <span asp-validation-for="QuickSubtraction" class="text-danger small"></span>
                </div>
            </div>

            <hr class="my-4" />
            <div class="text-end">
                <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">
                    <i class="fa-solid fa-floppy-disk me-2"></i> Cập nhật
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}