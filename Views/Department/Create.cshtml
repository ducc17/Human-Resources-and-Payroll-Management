@model SmartHR_Payroll.Models.Department

<div class="container mt-4">
    <div class="card shadow-sm border-0 w-50 mx-auto">
        <div class="card-header bg-primary text-white"><h5 class="mb-0">Thêm mới Phòng ban</h5></div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="needs-validation" novalidate>
                <div class="alert alert-info py-2 small">
                    <i class="bi bi-info-circle"></i> Mã phòng ban (Code) sẽ được hệ thống tự động sinh dựa trên Tên (VD: Ban Giám Đốc -> BGD123).
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Tên phòng ban</label>
                    <input asp-for="Name" class="form-control" required />
                    <div class="invalid-feedback">
                        Vui lòng nhập tên phòng ban.
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Chọn Quản lý (Manager)</label>
                    <select asp-for="ManagerId" class="form-select" asp-items="ViewBag.Employees">
                        <option value="">-- Để trống nếu chưa bổ nhiệm --</option>
                    </select>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Lưu dữ liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
}