@model SmartHR_Payroll.ViewModels.Payslip.PayslipDetailViewModel
@{
    ViewData["Title"] = "Chi tiết Phiếu Lương";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark">Chi tiết Phiếu lương</h3>
    <div>
        <a href="javascript:history.back()" class="btn btn-outline-secondary fw-bold shadow-sm me-2">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
        </a>
        <a asp-action="Print" asp-route-id="@Model.PayslipId" target="_blank" class="btn btn-dark fw-bold shadow-sm">
            <i class="fa-solid fa-print me-1"></i> In / Xuất PDF
        </a>
    </div>
</div>

<div class="card border-0 shadow rounded-4 overflow-hidden mx-auto" style="max-width: 850px;">
    <!-- Header Phiếu lương -->
    <div class="bg-primary bg-gradient text-white p-4 text-center">
        <h2 class="fw-bold mb-1">PHIẾU LƯƠNG NHÂN VIÊN</h2>
        <h5 class="fw-light mb-0">@Model.PeriodName (@Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy"))</h5>
    </div>

    <div class="card-body p-4 p-md-5">
        <!-- Thông tin NV -->
        <div class="row mb-4 border-bottom pb-4">
            <div class="col-md-6">
                <p class="mb-1 text-muted small fw-bold text-uppercase">Họ và tên</p>
                <h5 class="fw-bold text-dark">@Model.FullName <span class="badge bg-secondary ms-2">@Model.EmployeeCode</span></h5>
            </div>
            <div class="col-md-6">
                <div class="row">
                    <div class="col-6">
                        <p class="mb-1 text-muted small fw-bold text-uppercase">Phòng ban</p>
                        <p class="fw-semibold text-dark mb-2">@Model.DepartmentName</p>

                        <p class="mb-1 text-muted small fw-bold text-uppercase">Ngày công thực tế</p>
                        <p class="fw-semibold text-dark mb-0">@Model.WorkingDays.ToString("0.0") ngày</p>
                    </div>
                    <div class="col-6">
                        <p class="mb-1 text-muted small fw-bold text-uppercase">Chức vụ</p>
                        <p class="fw-semibold text-dark mb-2">@Model.PositionName</p>

                        <p class="mb-1 text-muted small fw-bold text-uppercase">Nghỉ phép có lương</p>
                        <p class="fw-semibold text-dark mb-0">@Model.PaidLeaveDays.ToString("0.0") ngày</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chi tiết thu nhập và khấu trừ -->
        <div class="row g-4">
            <!-- Cột Thu nhập -->
            <div class="col-md-6">
                <h6 class="fw-bold text-success border-bottom pb-2 mb-3"><i class="fa-solid fa-plus-circle me-2"></i>THU NHẬP (EARNINGS)</h6>

                <div class="d-flex justify-content-between mb-2 border-bottom border-light pb-2">
                    <span class="text-dark fw-semibold">Lương theo ngày công</span>
                    <span class="fw-bold text-dark">@Model.BaseSalary.ToString("N0") đ</span>
                </div>

                <!-- Vòng lặp liệt kê chi tiết Phụ cấp -->
                <div class="ps-2 border-start border-2 border-success mb-3">
                    @foreach (var a in Model.AllowanceDetails)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small"><i class="fa-solid fa-caret-right me-1 text-success"></i> @a.Name</span>
                            <span class="fw-semibold text-success small">+ @a.Amount.ToString("N0") đ</span>
                        </div>
                    }
                    @if (!Model.AllowanceDetails.Any())
                    {
                        <div class="text-muted small fst-italic">Không có phụ cấp</div>
                    }
                </div>

                <hr class="border-secondary border-opacity-25" />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold text-dark">Tổng thu nhập (Gross)</span>
                    <span class="fw-bold text-success fs-5">@Model.GrossSalary.ToString("N0") đ</span>
                </div>
            </div>

            <!-- Cột Khấu trừ -->
            <div class="col-md-6">
                <h6 class="fw-bold text-danger border-bottom pb-2 mb-3"><i class="fa-solid fa-minus-circle me-2"></i>KHẤU TRỪ (DEDUCTIONS)</h6>

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted fw-semibold">Trừ Bảo hiểm (BHXH, BHYT)</span>
                    <span class="fw-semibold text-danger">- @Model.SocialInsuranceAmount.ToString("N0") đ</span>
                </div>
                <div class="d-flex justify-content-between mb-3 border-bottom border-light pb-2">
                    <span class="text-muted fw-semibold">Thuế TNCN</span>
                    <span class="fw-semibold text-danger">- @Model.TaxAmount.ToString("N0") đ</span>
                </div>

                <!-- Vòng lặp liệt kê chi tiết Khấu trừ & Phạt -->
                <div class="ps-2 border-start border-2 border-danger mb-3">
                    @foreach (var d in Model.DeductionDetails)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small"><i class="fa-solid fa-caret-right me-1 text-danger"></i> @d.Name</span>
                            <span class="fw-semibold text-danger small">- @d.Amount.ToString("N0") đ</span>
                        </div>
                    }
                    @if (!Model.DeductionDetails.Any())
                    {
                        <div class="text-muted small fst-italic">Không có khấu trừ</div>
                    }
                </div>

                <hr class="border-secondary border-opacity-25" />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold text-dark">Tổng khấu trừ</span>
                    <span class="fw-bold text-danger fs-5">@Model.TotalDeductions.ToString("N0") đ</span>
                </div>
            </div>
        </div>

        <!-- THỰC LÃNH -->
        <div class="mt-5 p-4 bg-light rounded-4 border border-primary border-opacity-25 text-center">
            <h5 class="text-muted fw-bold mb-2 text-uppercase">THỰC LÃNH (NET PAY)</h5>
            <h1 class="display-5 fw-bold text-primary mb-3">@Model.NetSalary.ToString("N0") VNĐ</h1>

            <div class="d-flex justify-content-center gap-4 text-muted small">
                <span><i class="fa-solid fa-building-columns me-1"></i> NH: @Model.BankName</span>
                <span><i class="fa-solid fa-credit-card me-1"></i> STK: @Model.BankAccountNumber</span>
                @if (Model.PaymentDate.HasValue)
                {
                    <span class="text-success fw-bold"><i class="fa-solid fa-check-double me-1"></i> Đã trả ngày @Model.PaymentDate.Value.ToString("dd/MM/yyyy")</span>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Remarks))
        {
            <div class="mt-4 text-muted fst-italic small">
                <i class="fa-solid fa-circle-info me-1"></i> Ghi chú: @Model.Remarks
            </div>
        }
    </div>
</div>