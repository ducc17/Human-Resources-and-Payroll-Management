@model SmartHR_Payroll.ViewModels.Payslip.PayslipDetailViewModel
@{
    Layout = null; // Tắt Layout tổng để trang trắng tinh
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>In Phiếu Lương - @Model.EmployeeCode</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Times New Roman', Times, serif;
            background-color: #fff;
            color: #000;
        }

        .print-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }

        .header-title {
            text-align: center;
            text-transform: uppercase;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .table-custom th, .table-custom td {
            padding: 8px;
            border: 1px solid #000;
        }

        .table-custom th {
            background-color: #f0f0f0 !important;
            -webkit-print-color-adjust: exact;
        }

        .detail-row td {
            border-top: 0;
            border-bottom: 0;
            padding-top: 2px;
            padding-bottom: 2px;
            font-size: 0.9em;
            font-style: italic;
        }

        @@media print {
            .no-print {
                display: none;
            }
        }
    </style>
</head>
<body onload="window.print()">
    <div class="print-container">
        <div class="text-end mb-4 no-print">
            <button onclick="window.print()" class="btn btn-primary">In / Xuất PDF</button>
            <button onclick="window.close()" class="btn btn-secondary">Đóng</button>
        </div>

        <div class="d-flex justify-content-between border-bottom border-2 border-dark pb-2 mb-4">
            <div>
                <h4 class="fw-bold mb-0">CÔNG TY SMART HR</h4>
                <small>Hệ thống Quản trị Nhân sự & Tiền lương</small>
            </div>
            <div class="text-end">
                <p class="mb-0">Ngày in: @DateTime.Now.ToString("dd/MM/yyyy")</p>
            </div>
        </div>

        <h2 class="header-title">PHIẾU THANH TOÁN LƯƠNG</h2>
        <p class="text-center mb-4">Kỳ lương: @Model.PeriodName (Từ @Model.StartDate.ToString("dd/MM") đến @Model.EndDate.ToString("dd/MM/yyyy"))</p>

        <div class="row mb-3 fw-bold">
            <div class="col-6">Họ và tên: @Model.FullName</div>
            <div class="col-6 text-end">Mã NV: @Model.EmployeeCode</div>
            <div class="col-6">Phòng ban: @Model.DepartmentName</div>
            <div class="col-6 text-end">Chức vụ: @Model.PositionName</div>
        </div>

        <table class="table table-custom mb-4">
            <thead>
                <tr>
                    <th colspan="2" class="text-center w-50">1. THU NHẬP (EARNINGS)</th>
                    <th colspan="2" class="text-center w-50">2. KHẤU TRỪ (DEDUCTIONS)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-bold">Lương theo ngày công</td>
                    <td class="text-end fw-bold">@Model.BaseSalary.ToString("N0")</td>
                    <td class="fw-bold">Bảo hiểm bắt buộc</td>
                    <td class="text-end fw-bold">@Model.SocialInsuranceAmount.ToString("N0")</td>
                </tr>

                <tr>
                    <td class="fw-bold">Tổng phụ cấp</td>
                    <td class="text-end fw-bold">@Model.TotalAllowances.ToString("N0")</td>
                    <td class="fw-bold">Thuế TNCN</td>
                    <td class="text-end fw-bold">@Model.TaxAmount.ToString("N0")</td>
                </tr>

                <!-- Hiển thị chi tiết Phụ cấp bên trái, Khấu trừ bên phải -->
                @for (int i = 0; i < Math.Max(Model.AllowanceDetails.Count, Model.DeductionDetails.Count); i++)
                {
                    <tr class="detail-row text-muted">
                        <!-- Cột Phụ cấp -->
                        @if (i < Model.AllowanceDetails.Count)
                        {
                            <td>+ @Model.AllowanceDetails[i].Name</td>
                            <td class="text-end">@Model.AllowanceDetails[i].Amount.ToString("N0")</td>
                        }
                        else
                        {
                            <td></td>
                            <td></td>
                        }

                        <!-- Cột Khấu trừ -->
                        @if (i < Model.DeductionDetails.Count)
                        {
                            <td>- @Model.DeductionDetails[i].Name</td>
                            <td class="text-end">@Model.DeductionDetails[i].Amount.ToString("N0")</td>
                        }
                        else
                        {
                            <td></td>
                            <td></td>
                        }
                    </tr>
                }

                <tr class="fw-bold mt-2" style="border-top: 2px solid #000;">
                    <td>Tổng thu nhập (Gross)</td>
                    <td class="text-end">@Model.GrossSalary.ToString("N0")</td>
                    <td>Tổng khấu trừ</td>
                    <td class="text-end">@Model.TotalDeductions.ToString("N0")</td>
                </tr>
            </tbody>
        </table>

        <div class="d-flex justify-content-between align-items-center border border-dark p-3 mb-4">
            <h4 class="fw-bold mb-0">THỰC LÃNH (NET PAY)</h4>
            <h3 class="fw-bold mb-0">@Model.NetSalary.ToString("N0") VNĐ</h3>
        </div>

        <p><strong>Hình thức chi trả:</strong> Chuyển khoản (Ngân hàng: @Model.BankName - STK: @Model.BankAccountNumber)</p>
        <p><em>(Đây là phiếu lương điện tử được xuất từ hệ thống, không cần chữ ký)</em></p>
    </div>
</body>
</html>